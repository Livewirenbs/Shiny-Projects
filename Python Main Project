import tkinter as tk
from tkinter import messagebox, ttk
import sqlite3
from datetime import datetime
import winsound

ADMIN_USER = "admin"
ADMIN_PASS = "1234"

# ===== DATABASE =====
conn = sqlite3.connect("votes.db")
cur = conn.cursor()

cur.execute("""
CREATE TABLE IF NOT EXISTS registered_voters(
    voter_id TEXT PRIMARY KEY,
    dob TEXT,
    has_voted INTEGER DEFAULT 0
)
""")

cur.execute("""
CREATE TABLE IF NOT EXISTS votes(
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    voter_id TEXT,
    candidate TEXT,
    time TEXT,
    booth TEXT
)
""")

conn.commit()

# Dummy voters
for i in range(1, 51):
    voter_id = f"V{1000+i}"
    cur.execute("""
    INSERT OR IGNORE INTO registered_voters (voter_id, dob)
    VALUES (?,?)
    """, (voter_id, "2000-01-01"))
conn.commit()

# ===== FUNCTIONS =====
def beep():
    winsound.Beep(1000, 200)

def calculateAge(dob):
    birth = datetime.strptime(dob, "%Y-%m-%d")
    today = datetime.today()
    return today.year - birth.year - ((today.month, today.day) < (birth.month, birth.day))

def is_voting_time():
    now = datetime.now().time()
    return datetime.strptime("10:00","%H:%M").time() <= now <= datetime.strptime("17:00","%H:%M").time()

# ===== MAIN WINDOW =====
root = tk.Tk()
root.title("Secure Online Voting System")
root.geometry("1000x650")
root.configure(bg="#dfe6e9")

frame = tk.Frame(root, bg="white", padx=40, pady=40)
frame.place(relx=0.5, rely=0.5, anchor="center")

tk.Label(frame, text="SECURE ONLINE VOTING SYSTEM",
