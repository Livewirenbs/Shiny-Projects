# ===== ADMIN LOGIN =====
def admin_login():
    win = tk.Toplevel(root)
    win.title("Admin Login")
    win.geometry("400x320")
    win.configure(bg="#dfe6e9")

    box = tk.Frame(win, bg="white", padx=20, pady=20)
    box.place(relx=0.5, rely=0.5, anchor="center")

    tk.Label(box, text="Admin Login",
             font=("Arial",20,"bold"),
             bg="white").pack(pady=10)

    # ✅ ADMIN INSTRUCTIONS
    tk.Label(box,
             text="Username: admin\nPassword: 1234",
             font=("Arial",10),
             bg="white",
             fg="gray").pack(pady=5)

    user = tk.Entry(box, font=("Arial",14))
    user.pack(pady=5)

    pwd = tk.Entry(box, show="*", font=("Arial",14))
    pwd.pack(pady=5)

    def check():
